{
  "manifest_version": 3,
  "name": "Trackr - Habit Tracking",
  "description": "Track your daily habits right in your new tab",
  "version": "1.0.0",
  "permissions": [
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "favicon.ico",
    "48": "logo192.png",
    "128": "logo512.png"
  }
}
