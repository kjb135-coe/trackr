{
  "manifest_version": 3,
  "name": "Trackr 2.0 - Smart Habit Tracking",
  "description": "Transform your new tab into a beautiful, intelligent habit tracking dashboard",
  "version": "2.0.0",
  "permissions": [
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "favicon.ico",
    "48": "logo192.png",
    "128": "logo512.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}